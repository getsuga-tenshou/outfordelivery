# Copy to terraform.tfvars (git-ignored) and fill in your values.

region       = "eu-central-1"
project      = "outfordelivery"

# Optional: an AWS CLI profile to use. Omit to use the default credential chain (env vars or ~/.aws).
# aws_profile = "outfordelivery"

# Your public IP as a /32 so only you can reach SSH and Kafka. Find it at https://checkip.amazonaws.com
allowed_cidr = "203.0.113.4/32"

# Email that will receive SLA-breach alerts. You must confirm the subscription from your inbox.
alert_email  = "you@example.com"

# Optional: an existing EC2 key pair name for SSH into the Kafka node.
# ec2_key_name = "my-ec2-keypair"

enable_redshift = false
